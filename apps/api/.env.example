DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=workflow_ai_dashboard
PORT=3001
TYPEORM_SYNCHRONIZE=true

# Optional: seed sample runs for screenshot-ready UI (only seeds when DB has 0 runs).
SEED_SAMPLE_RUNS=true

# Optional: add a small delay between simulation log steps (ms).
SIMULATION_STEP_DELAY_MS=120
